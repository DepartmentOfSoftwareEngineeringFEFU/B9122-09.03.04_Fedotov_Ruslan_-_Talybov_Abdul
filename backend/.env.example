APP_ENV=development
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=trading

TINKOFF_API_KEY=
USE_SANDBOX=true
SECRET_KEY=dev-secret-key-change-me
TOKEN_ENCRYPTION_KEY=dev-token-encryption-key-change-me

AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_MAX_AGE_SECONDS=3600

LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300

AUTO_SELL_WORKER_ENABLED=false
AUTO_SELL_MANUAL_PROCESS_ENABLED=false
AUTO_SELL_DRY_RUN=true
AUTO_SELL_POLL_SECONDS=60
AI_BOT_REAL_TRADING_ENABLED=false
BULK_TRADE_WORKER_ENABLED=false
BULK_TRADE_WORKER_POLL_SECONDS=60
BULK_TRADE_CSV_DIR=bulk_trade_exports
